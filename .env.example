# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="CryptoTrader AI"
APP_ENV=development                  # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string-in-production
APP_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── API ──────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
API_PORT=8000

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_secret
POSTGRES_DB=crypto_trader
DATABASE_URL=postgresql+asyncpg://trader:trader_secret@localhost:5432/crypto_trader

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ─── Exchange APIs ────────────────────────────────────────────────────────────
EXCHANGE_DEFAULT=binance

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Coinbase Advanced Trade
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Kraken
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ─── LLM / LangChain ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# LangSmith (optional tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=crypto-trader

# ─── Workers / Celery ─────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                      # json | text
LOG_FILE_PATH=logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── WebSocket ────────────────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30

# ─── Risk Management ──────────────────────────────────────────────────────────
MAX_POSITION_SIZE_PCT=10.0           # % of total portfolio per position
MAX_DAILY_LOSS_PCT=5.0               # Circuit breaker threshold
DEFAULT_STOP_LOSS_PCT=2.0
DEFAULT_TAKE_PROFIT_PCT=4.0

# ─── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
SENTRY_DSN=

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_APP_NAME="CryptoTrader AI"
